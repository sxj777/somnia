{
  "name": "somnia-alpha",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:env": "tsx scripts/check-env.ts",
    "check:predeploy": "tsx scripts/check-env.ts --predeploy",
    "check:wallet": "hardhat run scripts/check-wallet.js --network baseSepolia",
    "compile": "hardhat compile",
    "deploy:base-sepolia": "hardhat run scripts/deploy.js --network baseSepolia"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bufferutil",
      "utf-8-validate"
    ]
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.8",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-query": "^5.59.16",
    "lucide-react": "^0.468.0",
    "next": "^14.2.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.53",
    "wagmi": "^2.13.4"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^3.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.16",
    "hardhat": "^2.22.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
